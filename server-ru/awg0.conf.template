# Конфигурация интерфейса (Сервер РФ)
[Interface]
PrivateKey = ${SERVER_PRIV_KEY}
Address = 10.8.0.1/24
ListenPort = 51820
MTU = 1280

# AmneziaWG маскировка для обхода DPI
Jc = 4
Jmin = 50
Jmax = 1000
S1 = 80
S2 = 120
H1 = 1
H2 = 2
H3 = 3
H4 = 4

